{
	"name": "@watwowmap/pogo-data",
	"version": "0.1.0",
	"description": "TypeScript bindings for the Pokemon GO data API V1 endpoints.",
	"type": "module",
	"sideEffects": false,
	"files": [
		"dist",
		"README.md"
	],
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"scripts": {
		"build": "tsup src/index.ts --dts --format esm,cjs --sourcemap --clean",
		"typecheck": "tsc --noEmit -p tsconfig.json",
		"test": "bun test"
	},
	"engines": {
		"node": ">=18"
	}
}
